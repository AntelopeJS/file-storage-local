{
  "cacheFolder": ".antelope/cache",
  "modules": {
    "local": {
      "source": {
        "type": "local",
        "path": "."
      },
      "config": {
        "storagePath": ".antelope/cache/storage",
        "baseUrl": "http://localhost:3000",
        "defaultVisibility": "private",
        "uploadTokenExpiration": 3600,
        "readTokenExpiration": 300,
        "cleanupInterval": 300
      }
    }
  }
}
