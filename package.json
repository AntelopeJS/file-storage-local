{
  "name": "@antelopejs/file-storage-local",
  "version": "0.0.2",
  "description": "A file storage module that implements the file-storage interface of AntelopeJS with local filesystem storage. NOT compatible with clustering - use file-storage-s3 for multi-instance deployments.",
  "repository": {
    "type": "git",
    "url": "https://github.com/AntelopeJS/file-storage-local.git"
  },
  "keywords": [
    "antelopejs",
    "file-storage",
    "local",
    "filesystem",
    "upload",
    "development"
  ],
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "ajs project run -w -p playground",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "lint": "biome check .",
    "prepack": "pnpm run build",
    "release": "pnpm run lint && pnpm run test && pnpm run prepack && release-it",
    "test": "pnpm run build && ajs module test ."
  },
  "antelopeJs": {
    "implements": [
      "@antelopejs/interface-file-storage"
    ],
    "test": "src/test/antelope.test.ts"
  },
  "dependencies": {
    "@antelopejs/interface-api": "^0.0.2",
    "@antelopejs/interface-core": "^0.0.2",
    "@antelopejs/interface-file-storage": "^0.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.18",
    "release-it": "^19.2.4",
    "release-it-changelogen": "^0.1.0",
    "typescript": "^5.8.3",
    "rimraf": "^6.0.1"
  }
}
