{
  "name": "@antelopejs/file-storage-local",
  "version": "0.0.1",
  "description": "A file storage module that implements the file-storage interface of AntelopeJS with local filesystem storage. NOT compatible with clustering - use file-storage-s3 for multi-instance deployments.",
  "repository": {
    "type": "git",
    "url": "https://github.com/AntelopeJS/file-storage-local.git"
  },
  "keywords": [
    "antelopejs",
    "file-storage",
    "local",
    "filesystem",
    "upload",
    "development"
  ],
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "build": "tsc",
    "dev:prepare": "cd playground && ajs module imports install",
    "dev": "ajs project run -w -p playground",
    "format": "biome format --write .",
    "generate": "ajs module exports generate",
    "lint:fix": "biome check --write .",
    "lint": "biome check .",
    "prepack": "pnpm run build",
    "prepare": "ajs module imports install",
    "release": "pnpm run lint && pnpm run test && pnpm run prepack && release-it",
    "test": "ajs module test ."
  },
  "antelopeJs": {
    "exportsPath": "dist/interfaces",
    "imports": [
      "core@beta",
      "api@beta"
    ],
    "importsOptional": [],
    "test": {
      "project": "src/test/antelope.test.json",
      "folder": "dist/test"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.18",
    "chai": "^6.2.2",
    "release-it": "^19.0.2",
    "typescript": "^5.8.3"
  }
}
